{
  "manifest_version": 3,
  "name": "Cursivis Browser Bridge",
  "version": "0.1.0",
  "description": "Connects the active browser tab to the local Cursivis desktop app with explicit per-site permission.",
  "permissions": ["activeTab", "nativeMessaging", "scripting", "storage", "tabs"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Cursivis browser access"
  },
  "options_page": "options.html"
}
