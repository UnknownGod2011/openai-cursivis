{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursivis.app/schemas/browser-action-plan.v1.json",
  "title": "Cursivis Browser Action Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "goal", "needsClarification", "clarifyingQuestion", "steps"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "goal": { "type": "string", "minLength": 1, "maxLength": 500 },
    "needsClarification": { "type": "boolean" },
    "clarifyingQuestion": { "type": ["string", "null"], "maxLength": 500 },
    "steps": {
      "type": "array",
      "minItems": 0,
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "stableTargetId", "value", "checked"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$" },
          "kind": {
            "type": "string",
            "enum": ["set_value", "set_checked", "select_option", "focus", "highlight", "click_navigation", "submit_search", "submit"]
          },
          "stableTargetId": { "type": "string", "minLength": 1, "maxLength": 512 },
          "value": { "type": ["string", "null"], "maxLength": 32768 },
          "checked": { "type": ["boolean", "null"] }
        }
      }
    }
  }
}
