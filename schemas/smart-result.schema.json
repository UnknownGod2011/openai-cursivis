{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursivis.app/schemas/smart-result.v1.json",
  "title": "Cursivis Smart Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contextType", "intent", "confidence", "finalContent", "suggestedAction", "riskHint", "confirmationHint"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "contextType": { "type": "string", "enum": ["text", "email", "code", "question", "prose", "image", "form", "user_interface", "table", "other"] },
    "intent": { "type": "string", "enum": ["translate", "reply", "rewrite", "summarize", "explain", "debug", "extract", "identify", "answer", "other"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "finalContent": { "type": "string", "minLength": 1, "maxLength": 100000 },
    "suggestedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "summary"],
      "properties": {
        "type": { "type": "string", "enum": ["none", "replace_selection", "insert_text", "fill_form", "copy", "browser_plan"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    },
    "riskHint": { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "confirmationHint": { "type": "string", "enum": ["none", "context_dependent", "required"] }
  }
}
