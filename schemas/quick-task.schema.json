{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursivis.app/schemas/quick-task.v1.json",
  "title": "Cursivis Quick Task",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "displayName", "finalizedInstruction", "supportedContext", "outputMode", "mayProposeAction", "isExplicitlyApproved"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z0-9-]+$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "finalizedInstruction": { "type": "string", "minLength": 1, "maxLength": 12000 },
    "supportedContext": { "type": "string", "enum": ["text", "image", "text_and_image"] },
    "outputMode": { "type": "string", "enum": ["replacement_text", "analysis", "structured_data", "suggested_action"] },
    "mayProposeAction": { "type": "boolean" },
    "isExplicitlyApproved": { "const": true }
  }
}
