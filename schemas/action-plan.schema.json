{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursivis.app/schemas/action-plan.v1.json",
  "title": "Cursivis Action Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "planId", "goal", "contextFingerprint", "steps"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planId": { "type": "string", "format": "uuid" },
    "goal": { "type": "string", "minLength": 1, "maxLength": 500 },
    "contextFingerprint": { "type": "string", "minLength": 32, "maxLength": 128 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepId", "kind", "targetId", "expectedOutcome"],
      "properties": {
        "stepId": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[A-Za-z0-9._-]+$" },
        "kind": {
          "type": "string",
          "enum": ["copy", "insert_text", "replace_selection", "set_field_value", "set_checkbox", "select_option", "focus", "highlight", "navigate", "submit"]
        },
        "targetId": { "type": "string", "minLength": 1, "maxLength": 256 },
        "value": { "type": ["string", "null"], "maxLength": 100000 },
        "expectedOutcome": { "type": "string", "minLength": 1, "maxLength": 500 }
      }
    }
  }
}
