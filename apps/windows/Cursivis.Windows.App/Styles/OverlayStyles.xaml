            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="#FFB63273" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="#FF087F78" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="#FF9A6400" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="#FF087A42" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="#FF687383" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="#FFB42335" />
            <SolidColorBrush x:Key="OrbCoreBrush" Color="#F0FFFFFF" />
            <SolidColorBrush x:Key="OrbCoreBorderBrush" Color="#18000000" />
            <SolidColorBrush x:Key="OrbBadgeBrush" Color="#E8FFFFFF" />
