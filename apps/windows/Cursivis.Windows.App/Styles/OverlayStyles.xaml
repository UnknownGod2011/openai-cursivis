        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="OverlayShellBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayHeaderBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayContentBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayHairlineBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlaySubtleTextBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="OverlayButtonBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="OverlayButtonHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayButtonPressedBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonTextBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
            <SolidColorBrush x:Key="OverlayNoticeBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayErrorBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayErrorBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayErrorTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OrbIdleBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OrbListeningBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbThinkingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbGeneratingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="{ThemeResource SystemColorHotlightColor}" />
            <SolidColorBrush x:Key="OrbCoreBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OrbCoreBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OrbBadgeBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OrbChipBrush" Color="{ThemeResource SystemColorWindowColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="OverlayPillButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="{ThemeResource OverlayButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OverlayBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OverlayPrimaryPillButtonStyle" BasedOn="{StaticResource OverlayPillButtonStyle}" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource OverlayPrimaryButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayPrimaryButtonTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="OverlayIconButtonStyle" BasedOn="{StaticResource OverlayPillButtonStyle}" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>

    <Style x:Key="PanelToolbarButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="{ThemeResource OverlayButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OverlayHairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PanelIconButtonStyle" BasedOn="{StaticResource PanelToolbarButtonStyle}" TargetType="Button">
        <Setter Property="Width" Value="34" />
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="17" />
    </Style>

    <Style x:Key="PanelFooterButtonStyle" BasedOn="{StaticResource PanelToolbarButtonStyle}" TargetType="Button">
        <Setter Property="Height" Value="27" />
        <Setter Property="MinHeight" Value="27" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="OrbActionChipStyle" TargetType="Button">
        <Setter Property="Width" Value="104" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="7,2" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="FontSize" Value="9.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{ThemeResource OrbChipBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OrbCoreBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ChipSurface"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="ChipSurface.Background" Value="{ThemeResource OverlayButtonHoverBrush}" />
                                        <Setter Target="ChipSurface.BorderBrush" Value="{ThemeResource OrbGuidingBrush}" />
                                        <Setter Target="ChipContent.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="ChipSurface.Background" Value="{ThemeResource OverlayButtonPressedBrush}" />
                                        <Setter Target="ChipSurface.BorderBrush" Value="{ThemeResource OrbGuidingBrush}" />
                                        <Setter Target="ChipContent.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="ChipSurface.Opacity" Value="0.58" />
                                        <Setter Target="ChipContent.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Focused">
                                    <VisualState.Setters>
                                        <Setter Target="ChipSurface.BorderBrush" Value="{ThemeResource OrbGuidingBrush}" />
                                        <Setter Target="ChipSurface.BorderThickness" Value="2" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Unfocused" />
                                <VisualState x:Name="PointerFocused" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter
                            x:Name="ChipContent"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrbControlButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="MinWidth" Value="26" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="13" />
        <Setter Property="Background" Value="{ThemeResource OrbChipBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OrbCoreBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="OrbNavigationButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="14" />
        <Setter Property="MinHeight" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayMutedTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
</ResourceDictionary>
