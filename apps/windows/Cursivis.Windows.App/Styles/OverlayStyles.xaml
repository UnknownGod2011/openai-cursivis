<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="OverlayShellBrush" Color="#F3212429" />
            <SolidColorBrush x:Key="OverlayHeaderBrush" Color="#FA2A2D33" />
            <SolidColorBrush x:Key="OverlayContentBrush" Color="#FC17191D" />
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="#FF3B3F47" />
            <SolidColorBrush x:Key="OverlayHairlineBrush" Color="#FF30343B" />
            <SolidColorBrush x:Key="OverlayTextBrush" Color="#FFF7F7F5" />
            <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#FFABB2BC" />
            <SolidColorBrush x:Key="OverlaySubtleTextBrush" Color="#FF858D98" />
            <SolidColorBrush x:Key="OverlayButtonBrush" Color="#FF30343A" />
            <SolidColorBrush x:Key="OverlayButtonHoverBrush" Color="#FF3A3F46" />
            <SolidColorBrush x:Key="OverlayButtonPressedBrush" Color="#FF24272C" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="#FFF4F4F2" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonTextBrush" Color="#FF17191D" />
            <SolidColorBrush x:Key="OverlayNoticeBrush" Color="#FF222E3B" />
            <SolidColorBrush x:Key="OverlayErrorBrush" Color="#FF3A2226" />
            <SolidColorBrush x:Key="OverlayErrorBorderBrush" Color="#FF9D4954" />
            <SolidColorBrush x:Key="OverlayErrorTextBrush" Color="#FFFFB8C0" />
            <SolidColorBrush x:Key="OrbIdleBrush" Color="#FF8F98A6" />
            <SolidColorBrush x:Key="OrbListeningBrush" Color="#FF39D9A0" />
            <SolidColorBrush x:Key="OrbThinkingBrush" Color="#FF8EA0FF" />
            <SolidColorBrush x:Key="OrbGeneratingBrush" Color="#FFB28BFF" />
            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="#FFF477B5" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="#FF43D8CE" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="#FFFFC15A" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="#FF4BDD84" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="#FFA2AAB5" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="#FFFF7180" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="OverlayShellBrush" Color="#F4E7E7E5" />
            <SolidColorBrush x:Key="OverlayHeaderBrush" Color="#FCFAFAF9" />
            <SolidColorBrush x:Key="OverlayContentBrush" Color="#FCF8F8F7" />
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="#FFD0D3D5" />
            <SolidColorBrush x:Key="OverlayHairlineBrush" Color="#FFE0E2E2" />
            <SolidColorBrush x:Key="OverlayTextBrush" Color="#FF171A1F" />
            <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#FF626C78" />
            <SolidColorBrush x:Key="OverlaySubtleTextBrush" Color="#FF858D96" />
            <SolidColorBrush x:Key="OverlayButtonBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonHoverBrush" Color="#FFF0F1F0" />
            <SolidColorBrush x:Key="OverlayButtonPressedBrush" Color="#FFE3E5E4" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="#FF24272D" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayNoticeBrush" Color="#FFEAF3FC" />
            <SolidColorBrush x:Key="OverlayErrorBrush" Color="#FFFFECEE" />
            <SolidColorBrush x:Key="OverlayErrorBorderBrush" Color="#FFE3A1AA" />
            <SolidColorBrush x:Key="OverlayErrorTextBrush" Color="#FF8A1F31" />
            <SolidColorBrush x:Key="OrbIdleBrush" Color="#FF687383" />
            <SolidColorBrush x:Key="OrbListeningBrush" Color="#FF087E5B" />
            <SolidColorBrush x:Key="OrbThinkingBrush" Color="#FF5368D8" />
            <SolidColorBrush x:Key="OrbGeneratingBrush" Color="#FF7651CE" />
            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="#FFB63273" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="#FF087F78" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="#FF9A6400" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="#FF087A42" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="#FF687383" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="#FFB42335" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="OverlayShellBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayHeaderBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayContentBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayHairlineBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlaySubtleTextBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="OverlayButtonBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="OverlayButtonHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayButtonPressedBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonTextBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
            <SolidColorBrush x:Key="OverlayNoticeBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayErrorBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="OverlayErrorBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OverlayErrorTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OrbIdleBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="OrbListeningBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbThinkingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbGeneratingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="{ThemeResource SystemColorHotlightColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="OverlayPillButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="CornerRadius" Value="17" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="{ThemeResource OverlayButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource OverlayBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="OverlayPrimaryPillButtonStyle" BasedOn="{StaticResource OverlayPillButtonStyle}" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource OverlayPrimaryButtonBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource OverlayPrimaryButtonTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="OverlayIconButtonStyle" BasedOn="{StaticResource OverlayPillButtonStyle}" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="18" />
    </Style>
</ResourceDictionary>
