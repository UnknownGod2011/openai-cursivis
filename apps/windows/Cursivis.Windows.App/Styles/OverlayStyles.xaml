            <SolidColorBrush x:Key="OrbSpeakingBrush" Color="#FFF477B5" />
            <SolidColorBrush x:Key="OrbGuidingBrush" Color="#FF43D8CE" />
            <SolidColorBrush x:Key="OrbExecutingBrush" Color="#FFFFC15A" />
            <SolidColorBrush x:Key="OrbDoneBrush" Color="#FF4BDD84" />
            <SolidColorBrush x:Key="OrbCancelledBrush" Color="#FFA2AAB5" />
            <SolidColorBrush x:Key="OrbErrorBrush" Color="#FFFF7180" />
            <SolidColorBrush x:Key="OrbCoreBrush" Color="#EE0F141B" />
