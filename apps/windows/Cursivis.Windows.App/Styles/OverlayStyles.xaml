        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="OverlayShellBrush" Color="#D0FFFFFF" />
            <SolidColorBrush x:Key="OverlayHeaderBrush" Color="#B8FFFFFF" />
            <SolidColorBrush x:Key="OverlayContentBrush" Color="#B2FFFFFF" />
            <SolidColorBrush x:Key="OverlayBorderBrush" Color="#12000000" />
            <SolidColorBrush x:Key="OverlayHairlineBrush" Color="#10000000" />
            <SolidColorBrush x:Key="OverlayTextBrush" Color="#FF111418" />
            <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#FF67707A" />
            <SolidColorBrush x:Key="OverlaySubtleTextBrush" Color="#FF8C949C" />
            <SolidColorBrush x:Key="OverlayButtonBrush" Color="#EDFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonHoverBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonPressedBrush" Color="#FFF0F2F3" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonBrush" Color="#FF14141A" />
            <SolidColorBrush x:Key="OverlayPrimaryButtonTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayNoticeBrush" Color="#FFEAF3FC" />
            <SolidColorBrush x:Key="OverlayErrorBrush" Color="#FFFFECEE" />
            <SolidColorBrush x:Key="OverlayErrorBorderBrush" Color="#FFE3A1AA" />
            <SolidColorBrush x:Key="OverlayErrorTextBrush" Color="#FF8A1F31" />
