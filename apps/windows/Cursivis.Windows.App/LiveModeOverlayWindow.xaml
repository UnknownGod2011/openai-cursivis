<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cursivis.Windows.App.LiveModeOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="OverlayRoot"
        Width="388"
        Height="144"
        AutomationProperties.AutomationId="LiveModeOverlay"
        AutomationProperties.LiveSetting="Polite"
        Background="Transparent">
        <Border
            x:Name="Shell"
            Margin="6"
            Padding="14,11,12,11"
            Background="{ThemeResource OverlayShellBrush}"
            BorderBrush="{ThemeResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="22">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="36" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Height="22"
                        Padding="9,0"
                        VerticalAlignment="Center"
                        Background="{ThemeResource OrbBadgeBrush}"
                        BorderBrush="{ThemeResource OverlayHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource OverlayTextBrush}"
                            Text="Live Mode" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="7">
                        <TextBlock
                            x:Name="StatusText"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{ThemeResource OverlayMutedTextBrush}"
                            Text="Connecting" />
                        <Border
                            Width="72"
                            Height="3"
                            VerticalAlignment="Center"
                            Background="{ThemeResource OverlayHairlineBrush}"
                            CornerRadius="2">
                            <Border
                                x:Name="AudioLevelFill"
                                Width="0"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource OrbListeningBrush}"
                                CornerRadius="2" />
                        </Border>
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        MinWidth="54"
                        Height="26"
                        Padding="11,0"
                        AutomationProperties.AutomationId="EndLiveMode"
                        AutomationProperties.Name="End Live Mode"
                        Click="OnStopClicked"
                        Content="End"
                        Style="{StaticResource OverlayPillButtonStyle}" />
                </Grid>

                <Grid Grid.Row="1" ColumnSpacing="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource OverlaySubtleTextBrush}"
                        Text="You" />
                    <TextBlock
                        x:Name="UserTranscriptText"
                        Grid.Column="1"
                        MaxLines="2"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{ThemeResource OverlayTextBrush}"
                        Text="Listening…"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource OverlaySubtleTextBrush}"
                        Text="Cursivis" />
                    <TextBlock
                        x:Name="AssistantTranscriptText"
                        Grid.Column="1"
                        MaxLines="2"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{ThemeResource OverlayTextBrush}"
                        Text="Ready"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
