<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cursivis.Windows.App.ContextResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="OverlayRoot"
        Background="{ThemeResource OverlayShellBrush}"
        PointerPressed="OnOverlayPointerPressed">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnCloseAcceleratorInvoked" />
            <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAcceleratorInvoked" />
            <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OnReplaceAcceleratorInvoked" />
        </Grid.KeyboardAccelerators>

        <Border
            x:Name="RootShell"
            Padding="12"
            Background="{ThemeResource OverlayShellBrush}"
            BorderBrush="{ThemeResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="28">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="62" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="16,10"
                    Background="{ThemeResource OverlayHeaderBrush}"
                    BorderBrush="{ThemeResource OverlayHairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="19">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="128" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            x:Name="HeaderDragSurface"
                            Orientation="Horizontal"
                            Spacing="9"
                            VerticalAlignment="Center">
                            <Image
                                Width="24"
                                Height="24"
                                Source="Assets/Square44x44Logo.targetsize-48_altform-lightunplated.png"
                                Stretch="Uniform" />
                            <TextBlock
                                x:Uid="ContextResultBrand"
                                VerticalAlignment="Center"
                                FontSize="19"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource OverlayMutedTextBrush}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="7"
                            VerticalAlignment="Center">
                            <Button
                                x:Name="UndoButton"
                                x:Uid="ContextResultUndoButton"
                                AutomationProperties.AutomationId="ContextResultUndo"
                                Click="OnUndoClicked"
                                Style="{StaticResource OverlayPillButtonStyle}" />
                            <Button
                                x:Name="InsertButton"
                                x:Uid="ContextResultInsertButton"
                                AutomationProperties.AutomationId="ContextResultInsert"
                                Click="OnInsertClicked"
                                Style="{StaticResource OverlayPrimaryPillButtonStyle}" />
                            <Button
                                x:Name="TakeActionButton"
                                x:Uid="ContextResultTakeActionButton"
                                AutomationProperties.AutomationId="ContextResultTakeAction"
                                Click="OnTakeActionClicked"
                                Style="{StaticResource OverlayPillButtonStyle}" />
                            <Button
                                x:Name="MoreOptionsButton"
                                x:Uid="ContextResultMoreOptionsButton"
                                AutomationProperties.AutomationId="ContextResultMoreOptions"
                                Click="OnMoreOptionsClicked"
                                Style="{StaticResource OverlayPillButtonStyle}" />
                            <Button
                                x:Name="ThemeButton"
                                x:Uid="ContextResultThemeButton"
                                AutomationProperties.AutomationId="ContextResultTheme"
                                Click="OnThemeClicked"
                                Style="{StaticResource OverlayIconButtonStyle}">
                                <FontIcon x:Name="ThemeIcon" FontSize="15" Glyph="&#xE793;" />
                            </Button>
                            <Button
                                x:Uid="ContextResultSettingsButton"
                                AutomationProperties.AutomationId="ContextResultSettings"
                                Click="OnSettingsClicked"
                                Style="{StaticResource OverlayIconButtonStyle}">
                                <FontIcon FontSize="15" Glyph="&#xE713;" />
                            </Button>
                            <Button
                                x:Uid="ContextResultHeaderCloseButton"
                                AutomationProperties.AutomationId="ContextResultHeaderClose"
                                Click="OnCloseClicked"
                                Style="{StaticResource OverlayIconButtonStyle}">
                                <FontIcon FontSize="13" Glyph="&#xE711;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="18,15,18,14"
                    Background="{ThemeResource OverlayContentBrush}"
                    BorderBrush="{ThemeResource OverlayBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <TextBlock
                                    x:Uid="ContextResultOutputLabel"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}" />
                                <TextBlock
                                    Text="/"
                                    FontSize="12"
                                    Foreground="{ThemeResource OverlaySubtleTextBrush}" />
                                <TextBlock
                                    x:Name="OperationLabelText"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}" />
                                <TextBlock
                                    Text="·"
                                    FontSize="12"
                                    Foreground="{ThemeResource OverlaySubtleTextBrush}" />
                                <TextBlock
                                    x:Name="ContextLabelText"
                                    FontSize="12"
                                    Foreground="{ThemeResource OverlaySubtleTextBrush}" />
                            </StackPanel>
                            <ProgressRing
                                x:Name="StreamingRing"
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Right"
                                IsActive="False"
                                Visibility="Collapsed" />
                        </Grid>

                        <ScrollViewer
                            Grid.Row="1"
                            AutomationProperties.AutomationId="ContextResultScrollViewer"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            ZoomMode="Disabled">
                            <Grid x:Name="ResultContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ColorPreviewColumn" Width="0" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="ColorPreviewBorder"
                                    Width="88"
                                    Height="88"
                                    VerticalAlignment="Top"
                                    AutomationProperties.AutomationId="ContextResultColorPreview"
                                    BorderBrush="{ThemeResource OverlayBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="ResultText"
                                    Grid.Column="1"
                                    x:Uid="ContextResultText"
                                    AutomationProperties.AutomationId="ContextResultContent"
                                    AutomationProperties.LiveSetting="Polite"
                                    FontSize="18"
                                    Foreground="{ThemeResource OverlayTextBrush}"
                                    IsTextSelectionEnabled="True"
                                    LineHeight="27"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ScrollViewer>

                        <Border
                            x:Name="NoticeBorder"
                            Grid.Row="2"
                            Padding="12,9"
                            Background="{ThemeResource OverlayNoticeBrush}"
                            BorderBrush="{ThemeResource OverlayHairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    x:Name="NoticeIcon"
                                    Margin="2,1,0,0"
                                    FontSize="15"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}"
                                    Glyph="&#xE946;" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock
                                        x:Name="NoticeTitleText"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource OverlayTextBrush}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="NoticeMessageText"
                                        FontSize="12"
                                        Foreground="{ThemeResource OverlayMutedTextBrush}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3">
                            <TextBlock
                                x:Name="KeyboardHintText"
                                x:Uid="ContextResultKeyboardHint"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{ThemeResource OverlaySubtleTextBrush}" />
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="7">
                                <Button
                                    x:Name="CopyButton"
                                    x:Uid="ContextResultCopyButton"
                                    AutomationProperties.AutomationId="ContextResultCopy"
                                    Click="OnCopyClicked"
                                    Style="{StaticResource OverlayPillButtonStyle}" />
                                <Button
                                    x:Name="ReplaceButton"
                                    x:Uid="ContextResultReplaceButton"
                                    AutomationProperties.AutomationId="ContextResultReplace"
                                    Click="OnReplaceClicked"
                                    Style="{StaticResource OverlayPrimaryPillButtonStyle}" />
                                <Button
                                    x:Name="RefineButton"
                                    x:Uid="ContextResultRefineButton"
                                    AutomationProperties.AutomationId="ContextResultRefine"
                                    Click="OnRefineClicked"
                                    Style="{StaticResource OverlayPillButtonStyle}" />
                                <Button
                                    x:Uid="ContextResultCloseButton"
                                    AutomationProperties.AutomationId="ContextResultClose"
                                    Click="OnCloseClicked"
                                    Style="{StaticResource OverlayPillButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
