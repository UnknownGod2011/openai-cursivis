<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cursivis.Windows.App.ContextResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="OverlayRoot"
        Background="Transparent"
        KeyboardAcceleratorPlacementMode="Hidden"
        PointerPressed="OnOverlayPointerPressed">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnCloseAcceleratorInvoked" />
        </Grid.KeyboardAccelerators>

        <Border
            x:Name="RootShell"
            Padding="12"
            Background="{ThemeResource OverlayShellBrush}"
            BorderBrush="{ThemeResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="28">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="DragHeader"
                    Padding="12,8"
                    Background="{ThemeResource OverlayHeaderBrush}"
                    CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="HeaderDragSurface"
                            x:Uid="ContextResultBrand"
                            VerticalAlignment="Center"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource OverlayTextBrush}" />

                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                x:Name="UndoButton"
                                x:Uid="ContextResultUndoButton"
                                MinWidth="50"
                                Height="28"
                                Margin="0,0,6,0"
                                AutomationProperties.AutomationId="ContextResultUndo"
                                Click="OnUndoClicked"
                                Style="{StaticResource PanelToolbarButtonStyle}" />
                            <Button
                                x:Name="InsertButton"
                                x:Uid="ContextResultInsertButton"
                                MinWidth="58"
                                Height="28"
                                Margin="0,0,6,0"
                                AutomationProperties.AutomationId="ContextResultInsert"
                                Click="OnInsertClicked"
                                Style="{StaticResource PanelToolbarButtonStyle}" />
                            <Button
                                x:Name="TakeActionButton"
                                x:Uid="ContextResultTakeActionButton"
                                MinWidth="86"
                                Height="28"
                                Margin="0,0,6,0"
                                AutomationProperties.AutomationId="ContextResultTakeAction"
                                Click="OnTakeActionClicked"
                                Style="{StaticResource PanelToolbarButtonStyle}" />
                            <Button
                                x:Name="MoreOptionsButton"
                                x:Uid="ContextResultMoreOptionsButton"
                                MinWidth="88"
                                Height="28"
                                Margin="0,0,6,0"
                                AutomationProperties.AutomationId="ContextResultMoreOptions"
                                Click="OnMoreOptionsClicked"
                                Style="{StaticResource PanelToolbarButtonStyle}" />
                            <Button
                                x:Name="ThemeButton"
                                x:Uid="ContextResultThemeButton"
                                Width="34"
                                Height="34"
                                Margin="0,0,6,0"
                                AutomationProperties.AutomationId="ContextResultTheme"
                                Click="OnThemeClicked"
                                Style="{StaticResource PanelIconButtonStyle}">
                                <FontIcon
                                    x:Name="ThemeIcon"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="15"
                                    Glyph="&#x2600;" />
                            </Button>
                            <Button
                                x:Name="SettingsButton"
                                x:Uid="ContextResultSettingsButton"
                                Width="34"
                                Height="34"
                                AutomationProperties.AutomationId="ContextResultSettings"
                                Click="OnSettingsClicked"
                                Style="{StaticResource PanelIconButtonStyle}">
                                <FontIcon FontSize="14" Glyph="&#xE713;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Padding="12,10"
                    Background="{ThemeResource OverlayContentBrush}"
                    BorderBrush="{ThemeResource OverlayBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    x:Uid="ContextResultOutputLabel"
                                    FontSize="10.5"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}" />
                                <TextBlock
                                    Margin="6,0"
                                    FontSize="11"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}"
                                    Text="/" />
                                <TextBlock
                                    x:Name="OperationLabelText"
                                    FontSize="10.5"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource OverlayMutedTextBrush}" />
                                <TextBlock
                                    Margin="6,0"
                                    FontSize="10.5"
                                    Foreground="{ThemeResource OverlaySubtleTextBrush}"
                                    Text="·" />
                                <TextBlock
                                    x:Name="ContextLabelText"
                                    FontSize="10.5"
                                    Foreground="{ThemeResource OverlaySubtleTextBrush}" />
                            </StackPanel>
                            <ProgressRing
                                x:Name="StreamingRing"
                                Width="14"
                                Height="14"
                                HorizontalAlignment="Right"
                                IsActive="False"
                                Visibility="Collapsed" />
                        </Grid>

                        <ScrollViewer
                            Grid.Row="1"
                            Margin="0,7,0,0"
                            AutomationProperties.AutomationId="ContextResultScrollViewer"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            ZoomMode="Disabled">
                            <Grid x:Name="ResultContentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ColorPreviewColumn" Width="0" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    x:Name="ColorPreviewBorder"
                                    Width="72"
                                    Height="72"
                                    VerticalAlignment="Top"
                                    AutomationProperties.AutomationId="ContextResultColorPreview"
                                    BorderBrush="{ThemeResource OverlayBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="ResultText"
                                    Grid.Column="1"
                                    x:Uid="ContextResultText"
                                    AutomationProperties.AutomationId="ContextResultContent"
                                    AutomationProperties.LiveSetting="Polite"
                                    FontSize="15"
                                    Foreground="{ThemeResource OverlayTextBrush}"
                                    IsTextSelectionEnabled="True"
                                    LineHeight="21"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <TextBlock
                                x:Name="StatusMessageText"
                                MaxWidth="230"
                                VerticalAlignment="Center"
                                FontSize="10.5"
                                Foreground="{ThemeResource OverlayMutedTextBrush}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="Collapsed" />
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    x:Name="RefineButton"
                                    x:Uid="ContextResultRefineButton"
                                    MinWidth="54"
                                    Margin="0,0,6,0"
                                    AutomationProperties.AutomationId="ContextResultRefine"
                                    Click="OnRefineClicked"
                                    Style="{StaticResource PanelFooterButtonStyle}" />
                                <Button
                                    x:Uid="ContextResultCloseButton"
                                    MinWidth="50"
                                    AutomationProperties.AutomationId="ContextResultClose"
                                    Click="OnCloseClicked"
                                    Style="{StaticResource PanelFooterButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
