<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cursivis.Windows.App.RegionSelectionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="SelectionRoot"
        IsTabStop="True"
        Background="Transparent"
        PointerPressed="OnPointerPressed"
        PointerMoved="OnPointerMoved"
        PointerReleased="OnPointerReleased">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
        </Grid.KeyboardAccelerators>

        <Image
            x:Name="MonitorPreview"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Stretch="Fill" />
        <Border Background="#59000000" />

        <Canvas x:Name="SelectionCanvas">
            <Border
                x:Name="SelectionRectangle"
                Visibility="Collapsed"
                Background="#26459BFF"
                BorderBrush="#FF82B8FF"
                BorderThickness="2"
                CornerRadius="4" />

            <Border
                Canvas.Left="28"
                Canvas.Top="28"
                Padding="14,10"
                Background="#E61B1D22"
                BorderBrush="#665F6672"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="3">
                    <TextBlock
                        x:Uid="RegionSelectionTitle"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="White" />
                    <TextBlock
                        x:Uid="RegionSelectionHint"
                        FontSize="12"
                        Foreground="#FFD0D5DC" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
