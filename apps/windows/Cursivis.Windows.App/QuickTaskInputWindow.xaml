<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cursivis.Windows.App.QuickTaskInputWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="OverlayRoot" Background="Transparent">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
            <KeyboardAccelerator Key="Enter" Invoked="OnEnterInvoked" />
        </Grid.KeyboardAccelerators>
        <Border
            x:Name="ShellBorder"
            Padding="10,8,10,10"
            Background="{ThemeResource OverlayShellBrush}"
            BorderBrush="{ThemeResource OverlayBorderBrush}"
            BorderThickness="1"
            CornerRadius="20">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="DragHandle"
                    Background="Transparent" />

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="34" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Border
                            MinHeight="64"
                            Background="{ThemeResource OverlayContentBrush}"
                            BorderBrush="{ThemeResource OverlayBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14" />
                        <TextBox
                            x:Name="ContentTextBox"
                            x:Uid="QuickTaskInputTextBox"
                            AcceptsReturn="True"
                            AutomationProperties.AutomationId="QuickTaskTypedInput"
                            Background="Transparent"
                            BorderThickness="0"
                            MaxLength="50000"
                            Padding="12,8"
                            VerticalContentAlignment="Top"
                            FontSize="13"
                            FontWeight="Normal"
                            Foreground="{ThemeResource OverlayTextBrush}"
                            TextChanged="OnInputTextChanged"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="PlaceholderText"
                            Margin="14,10,8,0"
                            VerticalAlignment="Top"
                            FontSize="12.5"
                            Foreground="{ThemeResource OverlaySubtleTextBrush}"
                            IsHitTestVisible="False"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <Button
                        x:Name="RunButton"
                        Grid.Column="1"
                        Width="34"
                        Height="34"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="RunQuickTaskInput"
                        Click="OnRunClicked"
                        IsEnabled="False"
                        Style="{StaticResource PanelIconButtonStyle}">
                        <FontIcon FontSize="14" Glyph="&#xE724;" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        Width="34"
                        Height="34"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="CancelQuickTaskInput"
                        AutomationProperties.Name="Cancel"
                        Click="OnCancelClicked"
                        Style="{StaticResource PanelIconButtonStyle}">
                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
