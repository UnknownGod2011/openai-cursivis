<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Cursivis.Windows.App.Controls.SettingsSectionHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Cursivis.Windows.App.Controls">

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                x:Name="TitleText"
                Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock
                x:Name="DescriptionText"
                MaxWidth="680"
                HorizontalAlignment="Left"
                Style="{StaticResource BodySecondaryTextStyle}" />
        </StackPanel>

        <controls:StatusIndicator
            x:Name="SectionStatus"
            Grid.Column="1"
            MinWidth="180"
            VerticalAlignment="Top" />
    </Grid>
</UserControl>
