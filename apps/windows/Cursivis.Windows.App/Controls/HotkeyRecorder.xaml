<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Cursivis.Windows.App.Controls.HotkeyRecorder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Unloaded="OnUnloaded">

    <Border Style="{StaticResource CardBorderStyle}">
        <Grid ColumnSpacing="16" RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="FunctionNameText"
                FontWeight="SemiBold"
                TextWrapping="Wrap" />
            <Button
                x:Name="CaptureButton"
                x:Uid="HotkeyCaptureButton"
                Grid.Column="1"
                AutomationProperties.Name="{x:Bind FunctionNameText.Text, Mode=OneWay}"
                Click="OnCaptureClicked"
                KeyDown="OnCaptureKeyDown"
                KeyUp="OnCaptureKeyUp" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
                <StackPanel Spacing="2">
                    <TextBlock x:Uid="HotkeyConfiguredLabel" Style="{StaticResource CaptionSecondaryTextStyle}" />
                    <TextBlock x:Name="ConfiguredChordText" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock x:Uid="HotkeyActiveLabel" Style="{StaticResource CaptionSecondaryTextStyle}" />
                    <TextBlock x:Name="ActiveChordText" FontFamily="Consolas" />
                </StackPanel>
            </StackPanel>

            <TextBlock
                x:Name="ValidationText"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Style="{StaticResource CaptionSecondaryTextStyle}" />
        </Grid>
    </Border>
</UserControl>
