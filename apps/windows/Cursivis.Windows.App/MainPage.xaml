<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cursivis.Windows.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView
            x:Name="SettingsNavigation"
            AutomationProperties.AutomationId="SettingsNavigation"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsTitleBarAutoPaddingEnabled="True"
            OpenPaneLength="264"
            PaneDisplayMode="Auto"
            SelectionChanged="OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="OverviewNavigationItem"
                    x:Uid="OverviewNavigationItem"
                    AutomationProperties.AutomationId="NavigateOverview"
                    Icon="Home"
                    IsSelected="True"
                    Tag="Overview" />
                <NavigationViewItem
                    x:Uid="OpenAiNavigationItem"
                    AutomationProperties.AutomationId="NavigateOpenAI"
                    Icon="Globe"
                    Tag="OpenAI" />
                <NavigationViewItem
                    x:Uid="InteractionNavigationItem"
                    AutomationProperties.AutomationId="NavigateInteraction"
                    Icon="TouchPointer"
                    Tag="Interaction" />
                <NavigationViewItem
                    x:Uid="QuickTaskNavigationItem"
                    AutomationProperties.AutomationId="NavigateQuickTask"
                    Icon="Edit"
                    Tag="QuickTask" />
                <NavigationViewItem
                    x:Uid="HotkeysNavigationItem"
                    AutomationProperties.AutomationId="NavigateHotkeys"
                    Icon="Keyboard"
                    Tag="Hotkeys" />
                <NavigationViewItem
                    x:Uid="VoiceNavigationItem"
                    AutomationProperties.AutomationId="NavigateVoice"
                    Icon="Microphone"
                    Tag="Voice" />
                <NavigationViewItem
                    x:Uid="BrowserNavigationItem"
                    AutomationProperties.AutomationId="NavigateBrowserIntegration"
                    Icon="World"
                    Tag="Browser" />
                <NavigationViewItem
                    x:Uid="PrivacyNavigationItem"
                    AutomationProperties.AutomationId="NavigatePrivacySafety"
                    Icon="Permissions"
                    Tag="Privacy" />
                <NavigationViewItem
                    x:Uid="DiagnosticsNavigationItem"
                    AutomationProperties.AutomationId="NavigateDiagnostics"
                    Icon="Repair"
                    Tag="Diagnostics" />
                <NavigationViewItem
                    x:Uid="AboutNavigationItem"
                    AutomationProperties.AutomationId="NavigateAbout"
                    Icon="Help"
                    Tag="About" />
            </NavigationView.MenuItems>

            <Frame
                x:Name="ContentFrame"
                AutomationProperties.AutomationId="SettingsContentFrame"
                IsNavigationStackEnabled="False" />
        </NavigationView>
    </Grid>
</Page>
